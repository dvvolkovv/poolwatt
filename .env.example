DATABASE_URL=postgresql://poolwatt:CHANGE_ME@127.0.0.1:5432/poolwatt
REDIS_URL=redis://127.0.0.1:6379
NEXTAUTH_URL=https://poolwatt.com
NEXTAUTH_SECRET=CHANGE_ME

# OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=

# Admin bootstrap. Comma-separated entries with prefixes:
#   email:foo@bar.com
#   telegram:123456789
#   github:octocat
ADMIN_WHITELIST=

# Energy data sources (used in Phase 2)
GRID_REFRESH_SEC=60
WEATHER_API_KEY=
PUBLIC_GRID_API_URL=

# Mapbox (public token, safe for client-side)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Email (Resend) — optional. Without these, approve/reject emails are silently skipped.
RESEND_API_KEY=
RESEND_FROM_EMAIL=notifications@poolwatt.com

# Address that receives a notification email for every new build request.
# Optional — when unset, the notification is skipped (logged with warn).
ADMIN_EMAIL=
